// Welcome to Gwinnett — New Resident Guide
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to Gwinnett — Gwinnett.cc</title>
  <meta name="description" content="Everything you need to get settled in Gwinnett County — curated for new residents." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ====== HEADER ====== -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="wordmark">Gwinnett.cc</a>
      <nav class="site-nav">
        <a href="/#directories">Directories</a>
        <a href="/#newsletter">Newsletter</a>
        <a href="/#contact">Contact</a>
      </nav>
    </div>
  </header>

  <!-- ====== HERO ====== -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">New Resident Guide</p>
      <h1 class="hero-headline">Welcome to Gwinnett County</h1>
      <p class="hero-sub">
        Everything you need to get settled — curated for new residents.
      </p>
    </div>
  </section>

  <!-- ====== RESOURCES ====== -->
  <section class="section resources">
    <div class="container">
      <div class="resource-grid">

        <div class="resource-card">
          <h2 class="resource-card-title">County &amp; City Government</h2>
          <ul class="resource-list">
            <li><a href="https://www.gwinnettcounty.com" target="_blank" rel="noopener">Gwinnett County</a></li>
            <li><a href="https://www.lawrencevillega.org" target="_blank" rel="noopener">City of Lawrenceville</a></li>
            <li><a href="https://www.duluthga.net" target="_blank" rel="noopener">City of Duluth</a></li>
            <li><a href="https://www.suwanee.com" target="_blank" rel="noopener">City of Suwanee</a></li>
            <li><a href="https://www.norcrossga.net" target="_blank" rel="noopener">City of Norcross</a></li>
            <li><a href="https://www.peachtreecornersga.gov" target="_blank" rel="noopener">Peachtree Corners</a></li>
            <li><a href="https://drives.ga.gov" target="_blank" rel="noopener">Vehicle Registration (DRIVES)</a></li>
            <li><a href="https://mvp.sos.ga.gov" target="_blank" rel="noopener">Voter Registration</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Schools &amp; Education</h2>
          <ul class="resource-list">
            <li><a href="https://www.gcps.edu" target="_blank" rel="noopener">Gwinnett County Public Schools</a></li>
            <li><a href="https://www.ggc.edu" target="_blank" rel="noopener">Georgia Gwinnett College</a></li>
            <li><a href="https://www.gwinnetttech.edu" target="_blank" rel="noopener">Gwinnett Technical College</a></li>
            <li><a href="https://www.gwinnettpl.org" target="_blank" rel="noopener">Gwinnett Public Library</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Healthcare</h2>
          <ul class="resource-list">
            <li><a href="https://www.northside.com/gwinnett" target="_blank" rel="noopener">Northside Hospital Gwinnett</a></li>
            <li><a href="https://www.piedmont.org/locations/piedmont-eastside" target="_blank" rel="noopener">Piedmont Eastside Medical Center</a></li>
            <li><a href="https://www.gwinnettcounty.com/health" target="_blank" rel="noopener">Gwinnett County Health Department</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Community &amp; Tourism</h2>
          <ul class="resource-list">
            <li><a href="https://www.exploregwinnett.com" target="_blank" rel="noopener">Explore Gwinnett</a></li>
            <li><a href="https://www.gwinnettchamber.org" target="_blank" rel="noopener">Gwinnett Chamber of Commerce</a></li>
            <li><a href="https://www.gassouthdistrict.com" target="_blank" rel="noopener">Gas South District</a></li>
            <li><a href="https://www.milb.com/gwinnett" target="_blank" rel="noopener">Gwinnett Stripers</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Utilities &amp; Services</h2>
          <ul class="resource-list">
            <li><a href="https://www.gwinnettcounty.com/water" target="_blank" rel="noopener">Gwinnett County Water</a></li>
            <li><a href="https://www.georgiapower.com" target="_blank" rel="noopener">Georgia Power</a></li>
            <li><a href="https://www.atlantagaslight.com" target="_blank" rel="noopener">Atlanta Gas Light</a></li>
            <li><a href="https://www.gwinnettcounty.com/solidwaste" target="_blank" rel="noopener">Waste Management Gwinnett</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Dining &amp; Local Life</h2>
          <ul class="resource-list">
            <li><a href="/restaurants">Gwinnett.cc Restaurants</a></li>
            <li><a href="/birthday-deals">Gwinnett.cc Birthday Deals</a></li>
            <li><a href="/home-services">Gwinnett.cc Home Services</a></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ====== FOOTER ====== -->
  <footer class="site-footer" id="contact">
    <div class="container footer-inner">
      <span class="footer-wordmark">Gwinnett.cc</span>
      <p class="footer-tagline">Community. Connections. Curated.</p>
      <div class="footer-links">
        <a href="mailto:hello@gwinnett.cc">hello@gwinnett.cc</a>
        <span class="footer-sep">&middot;</span>
        <a href="/privacy">Privacy</a>
      </div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Gwinnett.cc. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 16px;
    color: #111827;
    background: #ffffff;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section { padding: 4rem 0; }

  /* ── Header ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid #f3f4f6;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .wordmark {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #111827;
  }

  .site-nav { display: flex; gap: 2rem; }

  .site-nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: #374151;
    transition: color 0.15s;
  }
  .site-nav a:hover { color: #111827; }

  /* ── Hero ── */
  .hero {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 0.75rem;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: #6b7280;
    max-width: 520px;
    line-height: 1.6;
  }

  /* ── Resource grid ── */
  .resources { border-bottom: 1px solid #f3f4f6; }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .resource-card {
    padding: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #ffffff;
  }

  .resource-card-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 1rem;
  }

  .resource-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .resource-list a {
    font-size: 0.9rem;
    color: #374151;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .resource-list a:hover {
    color: #111827;
    border-bottom-color: #111827;
  }

  /* ── Footer ── */
  .site-footer {
    background: #f9fafb;
    border-top: 1px solid #f3f4f6;
    padding: 3rem 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-wordmark { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.03em; }
  .footer-tagline { font-size: 0.875rem; color: #6b7280; }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .footer-links a { color: #374151; transition: color 0.15s; }
  .footer-links a:hover { color: #111827; }
  .footer-sep { color: #d1d5db; }
  .footer-copy { font-size: 0.775rem; color: #9ca3af; margin-top: 0.25rem; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .resource-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .section { padding: 3rem 0; }
    .hero { padding: 2.5rem 0 2rem; }
    .resource-grid { grid-template-columns: 1fr; }
    .site-nav { gap: 1.25rem; }
  }
</style>
