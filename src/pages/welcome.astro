---
// Welcome to Gwinnett — New Resident Guide
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Welcome to Gwinnett — Gwinnett.cc"
  description="New to the county? Start here — curated resources for new residents."
>

  <!-- ====== HERO ====== -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">New Resident Guide</p>
      <h1 class="hero-headline">Welcome to Gwinnett County</h1>
      <p class="hero-sub">
        Everything you need to get settled — curated for new residents.
      </p>
    </div>
  </section>

  <!-- ====== RESOURCES ====== -->
  <section class="section resources">
    <div class="container">
      <div class="resource-grid">

        <div class="resource-card">
          <h2 class="resource-card-title">County &amp; City Government</h2>
          <ul class="resource-list">
            <li><a href="https://www.gwinnettcounty.com" target="_blank" rel="noopener">Gwinnett County</a></li>
            <li><a href="https://www.lawrencevillega.org" target="_blank" rel="noopener">City of Lawrenceville</a></li>
            <li><a href="https://www.duluthga.net" target="_blank" rel="noopener">City of Duluth</a></li>
            <li><a href="https://www.suwanee.com" target="_blank" rel="noopener">City of Suwanee</a></li>
            <li><a href="https://www.norcrossga.net" target="_blank" rel="noopener">City of Norcross</a></li>
            <li><a href="https://www.peachtreecornersga.gov" target="_blank" rel="noopener">Peachtree Corners</a></li>
            <li><a href="https://www.gwinnetttaxcommissioner.com/motor-vehicle" target="_blank" rel="noopener">Vehicle Registration</a></li>
            <li><a href="https://mvp.sos.ga.gov" target="_blank" rel="noopener">Voter Registration</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Schools &amp; Education</h2>
          <ul class="resource-list">
            <li><a href="https://www.gcpsk12.org/" target="_blank" rel="noopener">Gwinnett County Public Schools</a></li>
            <li><a href="https://www.bufordcityschools.org/" target="_blank" rel="noopener">Buford City Schools</a></li>
            <li><a href="https://www.ggc.edu" target="_blank" rel="noopener">Georgia Gwinnett College</a></li>
            <li><a href="https://www.gwinnetttech.edu" target="_blank" rel="noopener">Gwinnett Technical College</a></li>
            <li><a href="https://www.gwinnettpl.org" target="_blank" rel="noopener">Gwinnett Public Library</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Healthcare</h2>
          <ul class="resource-list">
            <li><a href="https://www.northside.com/gwinnett" target="_blank" rel="noopener">Northside Hospital Gwinnett</a></li>
            <li><a href="https://www.piedmont.org/locations/piedmont-eastside-medical-center" target="_blank" rel="noopener">Piedmont Eastside Medical Center</a></li>
            <li><a href="https://www.gnrhealth.com" target="_blank" rel="noopener">GNR Public Health</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Community &amp; Tourism</h2>
          <ul class="resource-list">
            <li><a href="https://www.exploregwinnett.com" target="_blank" rel="noopener">Explore Gwinnett</a></li>
            <li><a href="https://www.gwinnettchamber.org" target="_blank" rel="noopener">Gwinnett Chamber of Commerce</a></li>
            <li><a href="https://www.gassouthdistrict.com" target="_blank" rel="noopener">Gas South District</a></li>
            <li><a href="https://www.milb.com/gwinnett" target="_blank" rel="noopener">Gwinnett Stripers</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Utilities &amp; Services</h2>
          <ul class="resource-list">
            <li><a href="https://www.gwinnettcounty.com/government/departments/water" target="_blank" rel="noopener">Gwinnett County Water</a></li>
            <li><a href="https://www.georgiapower.com" target="_blank" rel="noopener">Georgia Power</a></li>
            <li><a href="https://www.atlantagaslight.com" target="_blank" rel="noopener">Atlanta Gas Light</a></li>
            <li><a href="https://www.gwinnettcounty.com/solidwaste" target="_blank" rel="noopener">Waste Management Gwinnett</a></li>
          </ul>
        </div>

        <div class="resource-card">
          <h2 class="resource-card-title">Dining &amp; Local Life</h2>
          <ul class="resource-list">
            <li><a href="/restaurants">Eat Local Gwinnett</a></li>
            <li><a href="/birthday-deals">Gwinnett Birthday Deals</a></li>
            <li><a href="/home-services">Gwinnett Home Services</a></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 0.75rem;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: #6b7280;
    max-width: 520px;
    line-height: 1.6;
  }

  /* ── Resource grid ── */
  .resources { border-bottom: 1px solid #f3f4f6; }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .resource-card {
    padding: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #ffffff;
  }

  .resource-card-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 1rem;
  }

  .resource-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .resource-list a {
    font-size: 0.9rem;
    color: #374151;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .resource-list a:hover {
    color: #111827;
    border-bottom-color: #111827;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .resource-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .hero { padding: 2.5rem 0 2rem; }
    .resource-grid { grid-template-columns: 1fr; }
  }
</style>
